# =============================================================================
# Elastic IOPS Monitor — Configuração
# Renomeie este arquivo para .env antes de executar o script.
# =============================================================================


# ─── MODIFIQUE - Endpoint do Elasticsearch ───────────────────────────────────────────────
ES_HOST=https://SEU-DEPLOYMENT.es.REGIAO.cloud.es.io


# ─── MODIFIQUE - Autenticação — escolha UMA das opções ───────────────────────────────────

# Opção A: API Key (recomendado)
ES_API_KEY=SUA_API_KEY_AQUI

# Opção B: Usuário e senha (deixe em branco se usar API Key, Remova os comentários para usar)
# ES_USER=elastic
# ES_PASSWORD=SUA_SENHA_AQUI


# ─── Configurações do Monitor ─────────────────────────────────────────────────

# Intervalo de amostragem (segundos) — tempo entre as 2 coletas para calcular delta.
# Valores menores = mais responsivo, mas mais chamadas ao cluster.
# Recomendado: entre 3 e 10 segundos.
SAMPLE_INTERVAL=10

# Intervalo de refresh (segundos) — pausa entre ciclos completos de exibição.
# Use 0 para executar uma única vez e sair.
# Recomendado para monitoramento contínuo: 30 a 60 segundos.
REFRESH_INTERVAL=30

# Roles que identificam nós "hot" (separados por vírgula, sem espaços).
# Exemplos comuns:
#   data_hot             → tier hot em clusters com ILM
#   data_hot,data_warm   → hot + warm juntos
#   data                 → clusters sem tier (todos os nós de dados)
HOT_ROLES=data_hot
